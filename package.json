{
  "name": "iron-crowns",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "main": "electron/main.cjs",
  "description": "A Feudalism-style semi-autobattler. Four houses, one throne.",
  "author": "DaisyConquest",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "lint": "eslint src --ext .js,.jsx",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:run": "vitest run",
    "start": "node server.cjs",
    "electron": "electron .",
    "electron:dev": "concurrently -k -n vite,electron -c \"yellow,cyan\" \"npm:dev\" \"wait-on http://localhost:5173 && electron .\"",
    "electron:build": "vite build && electron-builder",
    "electron:build:dir": "vite build && electron-builder --dir",
    "electron:publish": "vite build && electron-builder --publish always"
  },
  "dependencies": {
    "electron-updater": "^6.8.3",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.1",
    "concurrently": "^9.2.1",
    "electron": "^41.5.0",
    "electron-builder": "^26.8.1",
    "eslint": "^8.57.0",
    "eslint-plugin-react": "^7.34.1",
    "eslint-plugin-react-hooks": "^4.6.0",
    "vite": "^5.4.0",
    "vitest": "^2.1.0",
    "wait-on": "^9.0.5"
  },
  "build": {
    "appId": "com.daisyconquest.ironcrowns",
    "productName": "Iron Crowns",
    "copyright": "Copyright \u00a9 ${author}",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**",
      "electron/**",
      "package.json",
      "!node_modules/**/*.{md,markdown,map,ts}",
      "!**/{.eslintrc,.editorconfig,.prettierrc,.gitattributes}"
    ],
    "asar": true,
    "publish": [
      {
        "provider": "github",
        "owner": "REPLACE_ME",
        "repo": "DaisyConquest"
      }
    ],
    "win": {
      "target": [
        { "target": "nsis", "arch": ["x64"] }
      ],
      "artifactName": "IronCrowns-Setup-${version}.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "deleteAppDataOnUninstall": false
    },
    "mac": {
      "target": [{ "target": "dmg", "arch": ["x64", "arm64"] }],
      "category": "public.app-category.games",
      "artifactName": "IronCrowns-${version}-${arch}.${ext}"
    },
    "linux": {
      "target": [{ "target": "AppImage", "arch": ["x64"] }],
      "category": "Game",
      "artifactName": "IronCrowns-${version}-${arch}.${ext}"
    }
  }
}
